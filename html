<script>
function toggleProjects(){
  var panel=document.getElementById('projPanel');
  var btn=document.getElementById('projBtn');
  var open=panel.classList.contains('open');
  panel.classList.toggle('open');
  if(open){btn.innerHTML='View Projects <span class="proj-arrow">▼</span>';}
  else{btn.innerHTML='Hide Projects <span class="proj-arrow" style="transform:rotate(180deg);display:inline-block">▼</span>';setTimeout(function(){document.getElementById('projects').scrollIntoView({behavior:'smooth',block:'start'});},80);}
}
document.getElementById('viewProjBtn').addEventListener('click',function(e){
  e.preventDefault();
  var panel=document.getElementById('projPanel');
  var btn=document.getElementById('projBtn');
  if(!panel.classList.contains('open')){panel.classList.add('open');btn.innerHTML='Hide Projects <span class="proj-arrow" style="transform:rotate(180deg);display:inline-block">▼</span>';}
  setTimeout(function(){document.getElementById('projects').scrollIntoView({behavior:'smooth',block:'start'});},80);
});
var els=document.querySelectorAll('.reveal');
var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('vis');}});},{threshold:.08,rootMargin:'0px 0px -50px 0px'});
els.forEach(function(el){obs.observe(el);});
</script>
